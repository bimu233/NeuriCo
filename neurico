#!/bin/bash
# =============================================================================
# neurico - Simple CLI for containerized NeuriCo
#
# This wrapper script makes using the containerized version as simple as
# running the native Python scripts.
#
# Usage:
#   ./neurico fetch <url>              # Fetch from IdeaHub
#   ./neurico submit <idea.yaml>       # Submit an idea
#   ./neurico run <id> [options]       # Run research
#   ./neurico shell                    # Interactive shell
#   ./neurico build                    # Build container
#   ./neurico help                     # Show help
#
# =============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Delegate to the internal run.sh script
exec "$SCRIPT_DIR/docker/run.sh" "$@"
